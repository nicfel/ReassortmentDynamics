<beast version="2.0"
       namespace="beast.base.inference
                 :beast.core.util
                 :beast.core.parameter
                 :beast.base.evolution.alignment
                 :beast.base.evolution.likelihood
                 :beast.base.evolution.tree
                 :beast.base.evolution.tree.coalescent
				 :beast.base.evolution.alignment
				 :beast.base.inference.parameter
                 :beast.base.evolution.sitemodel
                 :beast.base.evolution.substitutionmodel
                 :beast.base.evolution.operators
                 :beast.math.distributions
				 :beast.base.inference.distribution
                 :beast.base.evolution.operator
                 :beast.base.inference.operator.kernel
                 :feast.simulation
                 :feast.fileio
                 :coalre.network
                 :coalre.statistics
                 :coalre.simulator
                 :coalre.distribution
                 :coalre.operators">

    <alignment id="seg1align" spec="AlignmentFromFasta" fileName="insert_seg1.fasta"/>
    <alignment id="seg2align" spec="AlignmentFromFasta" fileName="insert_seg2.fasta"/>
    <alignment id="seg3align" spec="AlignmentFromFasta" fileName="insert_seg3.fasta"/>
    <alignment id="seg4align" spec="AlignmentFromFasta" fileName="insert_seg4.fasta"/>
    <alignment id="seg5align" spec="AlignmentFromFasta" fileName="insert_seg5.fasta"/>
    <alignment id="seg6align" spec="AlignmentFromFasta" fileName="insert_seg6.fasta"/>
    <alignment id="seg7align" spec="AlignmentFromFasta" fileName="insert_seg7.fasta"/>
    <alignment id="seg8align" spec="AlignmentFromFasta" fileName="insert_seg8.fasta"/>
	

    <taxonSet spec="TaxonSet" id="taxonSet">
		insert_tips    
	</taxonSet>

    <traitSet spec="TraitSet" traitname="date-forward" id="traitSet" dateFormat="yyyy-M-dd">
		insert_heights
      <taxa idref="taxonSet"/>
    </traitSet>


    <run spec="MCMC" chainLength="2500000">
        <state  storeEvery="50000">
            <stateNode id="seg1tree" spec="Tree" taxonset="@taxonSet" trait="@traitSet"/>
            <stateNode id="seg2tree" spec="Tree" taxonset="@taxonSet" trait="@traitSet"/>
            <stateNode id="seg3tree" spec="Tree" taxonset="@taxonSet" trait="@traitSet"/>
            <stateNode id="seg4tree" spec="Tree" taxonset="@taxonSet" trait="@traitSet"/>
            <stateNode id="seg5tree" spec="Tree" taxonset="@taxonSet" trait="@traitSet"/>
            <stateNode id="seg6tree" spec="Tree" taxonset="@taxonSet" trait="@traitSet"/>
            <stateNode id="seg7tree" spec="Tree" taxonset="@taxonSet" trait="@traitSet"/>
            <stateNode id="seg8tree" spec="Tree" taxonset="@taxonSet" trait="@traitSet"/>

            <stateNode id="sigma" spec="RealParameter" lower="0.25" value="1"/>
            <stateNode id="sigma2" spec="RealParameter" lower="0.25" value="1"/>
            <stateNode id="popSize" spec="RealParameter" value="1.0293"/>
            <stateNode id="reassortmentRate" spec="RealParameter" lower="-10" value="0.1211"/>

            <stateNode id="logNe" spec="RealParameter" value="1 1.01"/>
            <stateNode id="rateShifts" spec="RealParameter" value="insert_times"/>
            <stateNode id="recoveryRate" spec="RealParameter" value="1.0"/>
            <stateNode id="InfectedToRho" spec="RealParameter" lower="-10" value="-8 -7"/>

            <parameter id="clockRate.c" spec="parameter.RealParameter" lower="0.0" name="stateNode">insert_clock_rate</parameter>
            
            <parameter id="mutationRate.s:seg1" spec="parameter.RealParameter" lower="0.0" name="stateNode">1.0</parameter>
            <parameter id="gammaShape.s:seg1" spec="parameter.RealParameter" lower="0.1" name="stateNode">1.0</parameter>
            <parameter id="freqParameter.s:seg1" spec="parameter.RealParameter" dimension="4" lower="0.0" name="stateNode" upper="1.0">0.25</parameter>
            <parameter id="kappa.s:seg1" spec="parameter.RealParameter" lower="0.0" name="stateNode">2.0</parameter>

            <parameter id="mutationRate.s:seg2" spec="parameter.RealParameter" lower="0.0" name="stateNode">1.0</parameter>
            <parameter id="gammaShape.s:seg2" spec="parameter.RealParameter" lower="0.1" name="stateNode">1.0</parameter>
            <parameter id="freqParameter.s:seg2" spec="parameter.RealParameter" dimension="4" lower="0.0" name="stateNode" upper="1.0">0.25</parameter>
            <parameter id="kappa.s:seg2" spec="parameter.RealParameter" lower="0.0" name="stateNode">2.0</parameter>

            <parameter id="mutationRate.s:seg3" spec="parameter.RealParameter" lower="0.0" name="stateNode">1.0</parameter>
            <parameter id="gammaShape.s:seg3" spec="parameter.RealParameter" lower="0.1" name="stateNode">1.0</parameter>
            <parameter id="freqParameter.s:seg3" spec="parameter.RealParameter" dimension="4" lower="0.0" name="stateNode" upper="1.0">0.25</parameter>
            <parameter id="kappa.s:seg3" spec="parameter.RealParameter" lower="0.0" name="stateNode">2.0</parameter>

            <parameter id="mutationRate.s:seg4" spec="parameter.RealParameter" lower="0.0" name="stateNode">1.0</parameter>
            <parameter id="gammaShape.s:seg4" spec="parameter.RealParameter" lower="0.1" name="stateNode">1.0</parameter>
            <parameter id="freqParameter.s:seg4" spec="parameter.RealParameter" dimension="4" lower="0.0" name="stateNode" upper="1.0">0.25</parameter>
            <parameter id="kappa.s:seg4" spec="parameter.RealParameter" lower="0.0" name="stateNode">2.0</parameter>

            <parameter id="mutationRate.s:seg5" spec="parameter.RealParameter" lower="0.0" name="stateNode">1.0</parameter>
            <parameter id="gammaShape.s:seg5" spec="parameter.RealParameter" lower="0.1" name="stateNode">1.0</parameter>
            <parameter id="freqParameter.s:seg5" spec="parameter.RealParameter" dimension="4" lower="0.0" name="stateNode" upper="1.0">0.25</parameter>
            <parameter id="kappa.s:seg5" spec="parameter.RealParameter" lower="0.0" name="stateNode">2.0</parameter>

            <parameter id="mutationRate.s:seg6" spec="parameter.RealParameter" lower="0.0" name="stateNode">1.0</parameter>
            <parameter id="gammaShape.s:seg6" spec="parameter.RealParameter" lower="0.1" name="stateNode">1.0</parameter>
            <parameter id="freqParameter.s:seg6" spec="parameter.RealParameter" dimension="4" lower="0.0" name="stateNode" upper="1.0">0.25</parameter>
            <parameter id="kappa.s:seg6" spec="parameter.RealParameter" lower="0.0" name="stateNode">2.0</parameter>

            <parameter id="mutationRate.s:seg7" spec="parameter.RealParameter" lower="0.0" name="stateNode">1.0</parameter>
            <parameter id="gammaShape.s:seg7" spec="parameter.RealParameter" lower="0.1" name="stateNode">1.0</parameter>
            <parameter id="freqParameter.s:seg7" spec="parameter.RealParameter" dimension="4" lower="0.0" name="stateNode" upper="1.0">0.25</parameter>
            <parameter id="kappa.s:seg7" spec="parameter.RealParameter" lower="0.0" name="stateNode">2.0</parameter>

            <parameter id="mutationRate.s:seg8" spec="parameter.RealParameter" lower="0.0" name="stateNode">1.0</parameter>
            <parameter id="gammaShape.s:seg8" spec="parameter.RealParameter" lower="0.1" name="stateNode">1.0</parameter>
            <parameter id="freqParameter.s:seg8" spec="parameter.RealParameter" dimension="4" lower="0.0" name="stateNode" upper="1.0">0.25</parameter>
            <parameter id="kappa.s:seg8" spec="parameter.RealParameter" lower="0.0" name="stateNode">2.0</parameter>

            <stateNode id="network" spec="SimulatedCoalescentNetwork"
                       nSegments="8" enableSegmentTreeUpdate="false">

                <traitSet idref="traitSet"/>

                <populationModel spec="ConstantPopulation">
                    <popSize spec="RealParameter" value="0.095922"/>
                </populationModel>

                <reassortmentRate spec="RealParameter" value="0.47263"/>
            </stateNode>
        </state>

        <init spec='beast.base.evolution.tree.ClusterTree' id='UPGMATree.t:XYZ26'
          initial="@seg1tree" clusterType='upgma' taxa='@seg1align'/>

        <init spec='coalre.util.InitFromTree' id='initnetwork'
          tree="@seg1tree" network='@network'>
        </init>


        <init spec="SegmentTreeInitializer" network="@network">
            <segmentTree idref="seg1tree"/>
            <segmentTree idref="seg2tree"/>
            <segmentTree idref="seg3tree"/>
            <segmentTree idref="seg4tree"/>
            <segmentTree idref="seg5tree"/>
            <segmentTree idref="seg6tree"/>
            <segmentTree idref="seg7tree"/>
            <segmentTree idref="seg8tree"/>

        </init>

        <distribution id="posterior" spec="CompoundDistribution">

            <distribution id="likelihood" spec="CompoundDistribution">
                <distribution id="treeLikelihood.seg1" spec="TreeLikelihood">
                    <data idref="seg1align"/>
                    <tree idref="seg1tree"/>
                    <siteModel spec="SiteModel" mutationRate="@mutationRate.s:seg1" gammaCategoryCount="4" shape="@gammaShape.s:seg1">
                        <substModel id="hky.s:seg1" spec="HKY" kappa="@kappa.s:seg1">
                            <frequencies id="estimatedFreqs.s:seg1" spec="Frequencies" frequencies="@freqParameter.s:seg1"/>
                        </substModel>
                    </siteModel>
                    <branchRateModel id="StrictClock.c" spec="beast.base.evolution.branchratemodel.StrictClockModel" clock.rate="@clockRate.c"/>
                </distribution>

                <distribution id="treeLikelihood.seg2" spec="TreeLikelihood">
                    <data idref="seg2align"/>
                    <tree idref="seg2tree"/>
                    <siteModel spec="SiteModel" mutationRate="@mutationRate.s:seg2" gammaCategoryCount="4" shape="@gammaShape.s:seg2">
                        <substModel id="hky.s:seg2" spec="HKY" kappa="@kappa.s:seg2">
                            <frequencies id="estimatedFreqs.s:seg2" spec="Frequencies" frequencies="@freqParameter.s:seg2"/>
                        </substModel>
                    </siteModel>
                    <branchRateModel idref="StrictClock.c"/>
                </distribution>

                <distribution id="treeLikelihood.seg3" spec="TreeLikelihood">
                    <data idref="seg3align"/>
                    <tree idref="seg3tree"/>
                    <siteModel spec="SiteModel" mutationRate="@mutationRate.s:seg3" gammaCategoryCount="4" shape="@gammaShape.s:seg3">
                        <substModel id="hky.s:seg3" spec="HKY" kappa="@kappa.s:seg3">
                            <frequencies id="estimatedFreqs.s:seg3" spec="Frequencies" frequencies="@freqParameter.s:seg3"/>
                        </substModel>
                    </siteModel>
                    <branchRateModel idref="StrictClock.c"/>
                </distribution>

                <distribution id="treeLikelihood.seg4" spec="TreeLikelihood">
                    <data idref="seg4align"/>
                    <tree idref="seg4tree"/>
                    <siteModel spec="SiteModel" mutationRate="@mutationRate.s:seg4" gammaCategoryCount="4" shape="@gammaShape.s:seg4">
                        <substModel id="hky.s:seg4" spec="HKY" kappa="@kappa.s:seg4">
                            <frequencies id="estimatedFreqs.s:seg4" spec="Frequencies" frequencies="@freqParameter.s:seg4"/>
                        </substModel>
                    </siteModel>
                    <branchRateModel idref="StrictClock.c"/>
                </distribution>

                <distribution id="treeLikelihood.seg5" spec="TreeLikelihood">
                    <data idref="seg5align"/>
                    <tree idref="seg5tree"/>
                    <siteModel spec="SiteModel" mutationRate="@mutationRate.s:seg5" gammaCategoryCount="4" shape="@gammaShape.s:seg5">
                        <substModel id="hky.s:seg5" spec="HKY" kappa="@kappa.s:seg5">
                            <frequencies id="estimatedFreqs.s:seg5" spec="Frequencies" frequencies="@freqParameter.s:seg5"/>
                        </substModel>
                    </siteModel>
                    <branchRateModel idref="StrictClock.c"/>
                </distribution>

                <distribution id="treeLikelihood.seg6" spec="TreeLikelihood">
                    <data idref="seg6align"/>
                    <tree idref="seg6tree"/>
                    <siteModel spec="SiteModel" mutationRate="@mutationRate.s:seg6" gammaCategoryCount="4" shape="@gammaShape.s:seg6">
                        <substModel id="hky.s:seg6" spec="HKY" kappa="@kappa.s:seg6">
                            <frequencies id="estimatedFreqs.s:seg6" spec="Frequencies" frequencies="@freqParameter.s:seg6"/>
                        </substModel>
                    </siteModel>
                    <branchRateModel idref="StrictClock.c"/>
                </distribution>

                <distribution id="treeLikelihood.seg7" spec="TreeLikelihood">
                    <data idref="seg7align"/>
                    <tree idref="seg7tree"/>
                    <siteModel spec="SiteModel" mutationRate="@mutationRate.s:seg7" gammaCategoryCount="4" shape="@gammaShape.s:seg7">
                        <substModel id="hky.s:seg7" spec="HKY" kappa="@kappa.s:seg7">
                            <frequencies id="estimatedFreqs.s:seg7" spec="Frequencies" frequencies="@freqParameter.s:seg7"/>
                        </substModel>
                    </siteModel>
                    <branchRateModel idref="StrictClock.c"/>
                </distribution>

                <distribution id="treeLikelihood.seg8" spec="TreeLikelihood">
                    <data idref="seg8align"/>
                    <tree idref="seg8tree"/>
                    <siteModel spec="SiteModel" mutationRate="@mutationRate.s:seg8" gammaCategoryCount="4" shape="@gammaShape.s:seg8">
                        <substModel id="hky.s:seg8" spec="HKY" kappa="@kappa.s:seg8">
                            <frequencies id="estimatedFreqs.s:seg8" spec="Frequencies" frequencies="@freqParameter.s:seg8"/>
                        </substModel>
                    </siteModel>
                    <branchRateModel idref="StrictClock.c"/>
                </distribution>


            </distribution>

            <distribution id="prior" spec="CompoundDistribution">
                <distribution id="networkPrior" spec="CoalescentWithReassortment" maxHeightRatio="1.1" redFactor="0.01">
                    <networkIntervals spec="NetworkIntervals" network="@network"/>

                    <!-- isconstant-->
                    <populationModel id="splinePop" spec="coalre.dynamics.SkygrowthNeDynamics" logNe="@logNe" rateShifts="@rateShifts"/>
                    <reassortmentRate idref="reassortmentRate"/>
                    <!--isconstant -->
                    
                    <!-- isISkyline-->
                    <populationModel id="splinePop" spec="coalre.dynamics.SkygrowthNeDynamics" logNe="@logNe" rateShifts="@rateShifts"/>
                    <timeVaryingReassortmentRates id="splinePop2" spec="coalre.dynamics.SkygrowthReassortmentRatesFromSkygrowthNe" neToReassortment="@InfectedToRho" rateShifts="@rateShifts"/>
                    <!--isISkyline -->

                    <!-- isNeSkyline-->
                    <populationModel id="splinePop" spec="coalre.dynamics.SkygrowthNeDynamics" logNe="@logNe" rateShifts="@rateShifts"/>
                    <timeVaryingReassortmentRates id="splinePop2" spec="coalre.dynamics.SkygrowthReassortmentRatesFromSkygrowthNe" logNe="@logNe" neToReassortment="@InfectedToRho" rateShifts="@rateShifts"/>
                    <!--isNeSkyline -->





                </distribution>

                <distribution id="parametersPrior" spec="CompoundDistribution">
                    <distribution spec="Prior" x="@popSize">
                        <distr spec="beast.base.inference.distribution.OneOnX"/>
                    </distribution>
                    <distribution spec="Prior" x="@reassortmentRate">
                        <distr spec="beast.base.inference.distribution.LogNormalDistributionModel" M="-1.7344" S="0.5"/>
                    </distribution>
                    <distribution spec="Prior">
                        <x spec="coalre.dynamics.Difference" arg="@logNe" independentAfter="insert_independent_after"/>
                        <distr spec="beast.base.inference.distribution.Normal" mean="0" sigma="@sigma"/>
                    </distribution>

                    <distribution spec="Prior" x="@sigma">
                        <distr spec="beast.base.inference.distribution.LogNormalDistributionModel" meanInRealSpace="true" M="1" S="0.5"/>
                    </distribution>

                    <!-- isinfectedSkyline-->
                    <distribution spec="Prior">
                        <x spec="coalre.dynamics.Difference" arg="@InfectedToRho" independentAfter="insert_independent_after"/>
                        <distr spec="beast.base.inference.distribution.Normal" mean="0" sigma="@sigma2"/>
                    </distribution>


                    <distribution spec="Prior" x="@sigma2">
                        <distr spec="beast.base.inference.distribution.LogNormalDistributionModel" meanInRealSpace="true" M="1" S="0.5"/>
                    </distribution>
                    <!--isinfectedSkyline -->

                    <!-- isISkyline-->
                    <distribution spec="Prior" >
                        <x spec="mascot.util.Mean" arg="@InfectedToRho"/>
                        <distr spec="beast.base.inference.distribution.Normal" mean="-5" sigma="1"/>
                    </distribution>
                    <!--isISkyline -->



                </distribution>
            </distribution>
        </distribution>



        <operator id="FixMeanMutationRatesOperator" spec="operator.kernel.BactrianDeltaExchangeOperator" delta="0.01" weight="0.25">
            <parameter idref="mutationRate.s:seg1"/>
            <parameter idref="mutationRate.s:seg2"/>
            <parameter idref="mutationRate.s:seg3"/>
            <parameter idref="mutationRate.s:seg4"/>
            <parameter idref="mutationRate.s:seg5"/>
            <parameter idref="mutationRate.s:seg6"/>
            <parameter idref="mutationRate.s:seg7"/>
            <parameter idref="mutationRate.s:seg8"/>
            <weightvector id="weightparameter" spec="parameter.IntegerParameter" dimension="2" estimate="false" lower="0" upper="0">insert_weights</weightvector>
        </operator>
        
        <!-- isconstant-->
        <operator id="migrationRatesScaler.s" spec="AdaptableOperatorSampler" weight="50.0">
            <parameter idref="logNe"/>
            <operator id="AVMNOperator.Mascot" spec="kernel.AdaptableVarianceMultivariateNormalOperator" allowNonsense="true" beta="0.05" burnin="400" initial="800" weight="1.0">
                <transformations id="AVMNSumTransform.Mascot" spec="operator.kernel.Transform$LogConstrainedSumTransform"/>
                <transformations id="AVMNLogTransform.Mascot" spec="operator.kernel.Transform$LogTransform">
                    <f idref="sigma"/>
                </transformations>
                <transformations id="AVMNNoTransform.Mascot" spec="operator.kernel.Transform$NoTransform">
                    <f idref="logNe"/>
                </transformations>
            </operator>
            <operator id="SkylineNe.camel.ScalerX.t" spec="beast.base.inference.operator.kernel.BactrianRandomWalkOperator" parameter="@logNe" scaleFactor="0.5" weight="1.0"/>
        </operator>
        <operator id="InfectedToRhoScaler1.s:" spec="AdaptableOperatorSampler" weight="1.0">
            <parameter idref="sigma"/>
            <operator idref="AVMNOperator.Mascot"/>
            <operator id="InfectedToRho.ScalerX1.t" spec="beast.base.evolution.operator.kernel.BactrianScaleOperator" parameter="@sigma" scaleFactor="0.5" weight="1.0"/>
        </operator>
        <operator id="reassortmentRateScaler" spec="beast.base.evolution.operator.ScaleOperator"
                  weight="5.0"  scaleFactor="0.8" optimise="false" parameter="@reassortmentRate">
        </operator>
        <!--isconstant -->


        <!-- isinfectedSkyline-->
        <operator id="migrationRatesScaler.s" spec="AdaptableOperatorSampler" weight="15.0">
            <parameter idref="logNe"/>
            <operator id="AVMNOperator.Mascot" spec="kernel.AdaptableVarianceMultivariateNormalOperator" allowNonsense="true" beta="0.05" burnin="400" initial="800" weight="1.0">
                <transformations id="AVMNSumTransform.Mascot" spec="operator.kernel.Transform$LogConstrainedSumTransform"/>
                <transformations id="AVMNLogTransform.Mascot" spec="operator.kernel.Transform$LogTransform">
                    <f idref="sigma"/>
                    <f idref="sigma2"/>
                </transformations>
                <transformations id="AVMNNoTransform.Mascot" spec="operator.kernel.Transform$NoTransform">
                    <f idref="InfectedToRho"/>
                    <f idref="logNe"/>
                </transformations>
            </operator>
            <operator id="SkylineNe.camel.ScalerX.t" spec="beast.base.inference.operator.kernel.BactrianRandomWalkOperator" parameter="@logNe" scaleFactor="0.5" weight="1.0"/>
        </operator>
        <operator id="InfectedToRhoScaler.s:" spec="AdaptableOperatorSampler" weight="15.0">
            <parameter idref="InfectedToRho"/>
            <operator idref="AVMNOperator.Mascot"/>
            <operator id="InfectedToRho.ScalerX.t" spec="beast.base.inference.operator.kernel.BactrianRandomWalkOperator" parameter="@InfectedToRho" scaleFactor="0.5" weight="1.0"/>
        </operator>
        <operator id="InfectedToRhoScaler1.s:" spec="AdaptableOperatorSampler" weight="5.0">
            <parameter idref="sigma"/>
            <operator idref="AVMNOperator.Mascot"/>
            <operator id="InfectedToRho.ScalerX1.t" spec="beast.base.evolution.operator.kernel.BactrianScaleOperator" parameter="@sigma" scaleFactor="0.5" weight="1.0"/>
        </operator>
        <operator id="InfectedToRhoScaler2.s:" spec="AdaptableOperatorSampler" weight="5.0">
            <parameter idref="sigma2"/>
            <operator idref="AVMNOperator.Mascot"/>
            <operator id="InfectedToRho.ScalerX2.t" spec="beast.base.evolution.operator.kernel.BactrianScaleOperator" parameter="@sigma2" scaleFactor="0.5" weight="1.0"/>
        </operator>

        <!--isinfectedSkyline -->



        <operator id="gammaShapeScaler.s:seg1" spec="AdaptableOperatorSampler" weight="0.05">
            <parameter idref="gammaShape.s:seg1"/>
            <operator id="AVMNOperator.seg1" spec="kernel.AdaptableVarianceMultivariateNormalOperator" allowNonsense="true" beta="0.05" burnin="400" initial="800" weight="1.0">
                <transformations spec="operator.kernel.Transform$LogConstrainedSumTransform">
                    <f idref="freqParameter.s:seg1"/>
                </transformations>
                <transformations spec="operator.kernel.Transform$LogTransform">
                    <f idref="gammaShape.s:seg1"/>
                    <f idref="kappa.s:seg1"/>
                </transformations>
            </operator>
            <operator id="gammaShapeScalerX.s:seg1" spec="kernel.BactrianScaleOperator" parameter="@gammaShape.s:seg1" scaleFactor="0.5" upper="10.0" weight="0.1"/>
        </operator>

        <operator id="FrequenciesExchanger.s:seg1" spec="AdaptableOperatorSampler" weight="0.05">
            <parameter idref="freqParameter.s:seg1"/>
            <operator idref="AVMNOperator.seg1"/>
            <operator id="FrequenciesExchangerX.s:seg1" spec="operator.kernel.BactrianDeltaExchangeOperator" delta="0.01" weight="0.1">
                <parameter idref="freqParameter.s:seg1"/>
            </operator>
        </operator>
        <operator id="KappaScaler.s:seg1" spec="AdaptableOperatorSampler" weight="0.05">
            <parameter idref="kappa.s:seg1"/>
            <operator idref="AVMNOperator.seg1"/>
            <operator id="KappaScalerX.s:seg1" spec="kernel.BactrianScaleOperator" parameter="@kappa.s:seg1" scaleFactor="0.1" upper="10.0" weight="0.1"/>
        </operator>



        <operator id="gammaShapeScaler.s:seg2" spec="AdaptableOperatorSampler" weight="0.05">
            <parameter idref="gammaShape.s:seg2"/>
            <operator id="AVMNOperator.seg2" spec="kernel.AdaptableVarianceMultivariateNormalOperator" allowNonsense="true" beta="0.05" burnin="400" initial="800" weight="1.0">
                <transformations spec="operator.kernel.Transform$LogConstrainedSumTransform">
                    <f idref="freqParameter.s:seg2"/>
                </transformations>
                <transformations spec="operator.kernel.Transform$LogTransform">
                    <f idref="gammaShape.s:seg2"/>
                    <f idref="kappa.s:seg2"/>
                </transformations>
            </operator>
            <operator id="gammaShapeScalerX.s:seg2" spec="kernel.BactrianScaleOperator" parameter="@gammaShape.s:seg2" scaleFactor="0.5" upper="10.0" weight="0.1"/>
        </operator>
        <operator id="FrequenciesExchanger.s:seg2" spec="AdaptableOperatorSampler" weight="0.05">
            <parameter idref="freqParameter.s:seg2"/>
            <operator idref="AVMNOperator.seg2"/>
            <operator id="FrequenciesExchangerX.s:seg2" spec="operator.kernel.BactrianDeltaExchangeOperator" delta="0.01" weight="0.1">
                <parameter idref="freqParameter.s:seg2"/>
            </operator>
        </operator>
        <operator id="KappaScaler.s:seg2" spec="AdaptableOperatorSampler" weight="0.05">
            <parameter idref="kappa.s:seg2"/>
            <operator idref="AVMNOperator.seg2"/>
            <operator id="KappaScalerX.s:seg2" spec="kernel.BactrianScaleOperator" parameter="@kappa.s:seg2" scaleFactor="0.1" upper="10.0" weight="0.1"/>
        </operator>

        <operator id="gammaShapeScaler.s:seg3" spec="AdaptableOperatorSampler" weight="0.05">
            <parameter idref="gammaShape.s:seg3"/>
            <operator id="AVMNOperator.seg3" spec="kernel.AdaptableVarianceMultivariateNormalOperator" allowNonsense="true" beta="0.05" burnin="400" initial="800" weight="1.0">
                <transformations spec="operator.kernel.Transform$LogConstrainedSumTransform">
                    <f idref="freqParameter.s:seg3"/>
                </transformations>
                <transformations spec="operator.kernel.Transform$LogTransform">
                    <f idref="gammaShape.s:seg3"/>
                    <f idref="kappa.s:seg3"/>
                </transformations>
            </operator>
            <operator id="gammaShapeScalerX.s:seg3" spec="kernel.BactrianScaleOperator" parameter="@gammaShape.s:seg3" scaleFactor="0.5" upper="10.0" weight="0.1"/>
        </operator>
        <operator id="FrequenciesExchanger.s:seg3" spec="AdaptableOperatorSampler" weight="0.05">
            <parameter idref="freqParameter.s:seg3"/>
            <operator idref="AVMNOperator.seg3"/>
