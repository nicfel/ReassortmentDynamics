<beast version="2.0"
       namespace="beast.core
                 :beast.core.util
                 :beast.core.parameter
                 :beast.evolution.alignment
                 :beast.evolution.likelihood
                 :beast.base.evolution.tree
                 :beast.base.evolution.tree.coalescent
                 :beast.base.evolution.sitemodel
                 :beast.base.evolution.substitutionmodel
                 :beast.evolution.operators
                 :beast.math.distributions
                 :feast.simulation
                 :coalre.network
                 :coalre.statistics
                 :coalre.simulator
                 :coalre.distribution
                 :coalre.operators">

    <run spec="GPSimulator" nSims="1">
        <simulationObject id="network_truth" spec="SIRwithReassortment" 
        fileName="master/$(filebase).trees" 
        transmissionRate="insert_transmission" 
        recoveryRate="insert_recovery" 
        waningImmunityRate="0.0" 
        reassortmenProbability="1.0" 
        samplingProbability="insert_sampling" 
        populationSize="insert_population_size" 
        simulationTime="100000" 
        nSegments="4" minSamples="10">
            <segmentTree id="seg1tree_truth" spec="Tree"/>
            <segmentTree id="seg2tree_truth" spec="Tree"/>
            <segmentTree id="seg3tree_truth" spec="Tree"/>
            <segmentTree id="seg4tree_truth" spec="Tree"/>
        </simulationObject>

        <logger spec="beast.base.inference.Logger" fileName="master/$(filebase).log" logEvery="1">
            <log idref="network_truth"/>
        </logger>
    </run>

</beast>
